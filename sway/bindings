# Press $MOD+O to change the theme of the Window Manager
bindsym $mod+o exec --no-startup-id "$HOME/.local/scripts/theme.sh"

# Press $MOD+P to change the Wallpaper
bindsym $mod+p exec --no-startup-id "$HOME/.local/scripts/wallpaper.sh -p"


bindsym $mod+Return exec $term
bindsym $mod+w kill
bindsym $mod+d exec $menu
bindsym $mod+n exec $browser
bindsym $mod+u exec swaylock -c 000000

# Sway Defaults
# Can be changed by editing the below

bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'
